<Application x:Class="AudioPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AudioPlayer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Стили и цвета Fluent Design (WPF-UI) -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />

            </ResourceDictionary.MergedDictionaries>

            <!-- ===== SVG-иконки ===== -->
            <!-- Настоящие .svg-файлы лежат в папке Icons/svg/ (рендерятся через SharpVectors,
                 см. SvgPathIcon.cs) и подключать их тут не нужно — они встраиваются в сборку
                 напрямую через <Resource Include="Icons\svg\**\*.svg" /> в Lumisense.csproj.
                 Чтобы поменять иконку — замени файл Icons/svg/IconXxx.svg на другой и пересобери
                 проект. Сама иконка на экране — local:SvgPathIcon с единственным обязательным
                 атрибутом Icon="IconXxx", создаётся заново под каждую кнопку. Подробности и как
                 задать размер по умолчанию — смотри Icons/svg/README.md. -->

            <local:IsOddIndexConverter x:Key="IsOddIndexConverter" />

            <!-- Кастомный тонкий Fluent-ползунок: применяется ко ВСЕМ Slider в приложении -->
            <Style TargetType="Slider">
                <Setter Property="Height" Value="24" />
                <Setter Property="Focusable" Value="True" />
                <!-- Ключевая настройка: клик по треку сразу переносит ползунок в точку клика,
                     а не сдвигает его пошагово на LargeChange -->
                <Setter Property="IsMoveToPointEnabled" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center" Background="Transparent">
                                <!-- Фоновая полоса (весь трек). Раньше была жёстко Height="4" с
                                     шириной на всю ширину контейнера (VerticalAlignment=Center)
                                     — то есть геометрия ТОЛЬКО горизонтального слайдера: у
                                     10 вертикальных слайдеров эквалайзера (см. SettingsWindow.xaml)
                                     это превращало полосу в приплюснутую по центру
                                     горизонтальную чёрточку вместо вертикальной колонки на всю
                                     высоту. Теперь размер переключается триггером по
                                     Orientation, привязанным через RelativeSource — он достаёт
                                     Slider.Orientation даже сквозь границу вложенного шаблона
                                     RepeatButton ниже, где resolve по x:Name недоступен. -->
                                <Border CornerRadius="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Background="{DynamicResource ControlStrongFillColorDefaultBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Height" Value="4" />
                                            <Setter Property="Width" Value="Auto" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Orientation}" Value="Vertical">
                                                    <Setter Property="Height" Value="Auto" />
                                                    <Setter Property="Width" Value="4" />
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Orientation="{TemplateBinding Orientation}" — вот собственно
                                     сама причина, почему вертикальные слайдеры не тащились
                                     мышью вообще: Track — отдельный класс со своим СОБСТВЕННЫМ
                                     свойством Orientation (Horizontal по умолчанию), которое
                                     WPF НЕ подхватывает из Slider автоматически просто по факту
                                     родства в шаблоне. Без этой привязки Track всегда считал
                                     себя горизонтальным и мапил перетаскивание мышью на X, а не
                                     на Y — то есть на вертикальных слайдерах эквалайзера
                                     вертикальное движение мыши в принципе ни на что не влияло. -->
                                <Track x:Name="PART_Track" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <!-- Тот же приём, что и у фоновой полосы выше: заполненная
                                                         акцентом часть трека "от начала до текущего значения"
                                                         должна быть тонкой поперёк оси движения и растянутой
                                                         вдоль неё — а вдоль какой оси это "вдоль", зависит от
                                                         Orientation родительского Slider. -->
                                                    <Border CornerRadius="2"
                                                            Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Height" Value="4" />
                                                                <Setter Property="Width" Value="Auto" />
                                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Orientation}" Value="Vertical">
                                                                        <Setter Property="Height" Value="Auto" />
                                                                        <Setter Property="Width" Value="4" />
                                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <!-- Уже и так растягивается на всю выделенную Track'ом
                                                         область в обе стороны (Height/Width не заданы —
                                                         дефолт Stretch), поэтому для этой, "прозрачной для
                                                         глаза" половины трека триггер по Orientation не
                                                         нужен — она только ловит клики мимо бегунка. -->
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb Width="16" Height="16" Cursor="Hand">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                             Stroke="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                             StrokeThickness="1.5" />
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Стилизация строк плейлиста: скруглённые карточки, ховер, акцентная подсветка выбранного трека.

                 Разделение треков между собой: раньше — линия снизу каждой строки, потом —
                 только нумерация без какого-либо фона (визуально пропадало на глаз). Теперь —
                 zebra striping: у каждой нечётной по счёту строки (AlternationIndex) свой
                 лёгкий фон-подложка (ControlFillColorDefaultBrush), у чётных — прозрачный.
                 Это задаётся триггером ниже (Style.Triggers), а не прямо в Background, потому
                 что AlternationIndex — это отдельное свойство самого ListViewItem, доступное
                 только когда ListView.AlternationCount > 0 (см. MainWindow.xaml).

                 Порядок важен: DataTrigger в Style.Triggers красит фон полосой ДО применения
                 шаблона, а ховер/выбор (ControlTemplate.Triggers ниже) красят именованный
                 элемент ItemBorder уже ПОСЛЕ — у триггеров шаблона приоритет выше, чем у
                 триггеров стиля, поэтому при наведении/выборе полоса всегда корректно
                 перекрывается акцентом, а не спорит с ним. -->
            <Style TargetType="ListViewItem">
                <Setter Property="Padding" Value="10,9" />
                <Setter Property="Margin" Value="2,3" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="ItemBorder" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background"
                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background"
                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <Binding RelativeSource="{RelativeSource Self}"
                                     Path="(ItemsControl.AlternationIndex)"
                                     Converter="{StaticResource IsOddIndexConverter}" />
                        </DataTrigger.Binding>
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
