<Application x:Class="AudioPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AudioPlayer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Стили и цвета Fluent Design (WPF-UI) -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />

            </ResourceDictionary.MergedDictionaries>

            <!-- ===== SVG-иконки ===== -->
            <!-- Настоящие .svg-файлы лежат в папке Icons/svg/ (рендерятся через SharpVectors,
                 см. SvgPathIcon.cs) и подключать их тут не нужно — они встраиваются в сборку
                 напрямую через <Resource Include="Icons\svg\**\*.svg" /> в Lumisense.csproj.
                 Чтобы поменять иконку — замени файл Icons/svg/IconXxx.svg на другой и пересобери
                 проект. Сама иконка на экране — local:SvgPathIcon с единственным обязательным
                 атрибутом Icon="IconXxx", создаётся заново под каждую кнопку. Подробности и как
                 задать размер по умолчанию — смотри Icons/svg/README.md. -->

            <local:IsOddIndexConverter x:Key="IsOddIndexConverter" />

            <!-- Кастомный тонкий Fluent-ползунок: применяется ко ВСЕМ Slider в приложении -->
            <Style TargetType="Slider">
                <Setter Property="Height" Value="24" />
                <Setter Property="Focusable" Value="True" />
                <!-- Ключевая настройка: клик по треку сразу переносит ползунок в точку клика,
                     а не сдвигает его пошагово на LargeChange -->
                <Setter Property="IsMoveToPointEnabled" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <!-- И Grid, и Track — ВСЕГДА Stretch по обеим осям (никакого
                                 VerticalAlignment/HorizontalAlignment="Center" на них самих).
                                 Это принципиально: у вертикальных слайдеров эквалайзера
                                 (Height="140") Track обязан реально ЗАНИМАТЬ все 140px по
                                 высоте, чтобы у него было где считать позицию бегунка при
                                 перетаскивании — если центрировать Track по своему "естественному"
                                 (сжатому) размеру вместо растягивания на всё доступное
                                 пространство, диапазон перетаскивания схлопывается почти до
                                 нуля, и слайдер визуально почти не двигается. Тонкая полоса
                                 (4px) — это НЕ про сжатие Track/Grid, а только про декоративные
                                 Border ниже, у которых размер вдоль поперечной оси зафиксирован
                                 явно (Height/Width=4), а выравнивание по ней — Center, но не
                                 локальным атрибутом на самом элементе (WPF отдаёт локальным
                                 значениям приоритет строго ВЫШЕ, чем сеттерам стиля, включая
                                 триггерные — задать и то, и другое на одном элементе означает,
                                 что триггер не сможет переопределить локальное значение и
                                 останется мёртвым кодом), а исключительно через Style ниже —
                                 это и есть та ошибка, которая была здесь минуту назад. -->
                            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
                                <!-- Фоновая полоса (весь трек) — тонкая поперёк оси движения,
                                     на всю длину вдоль неё. Какая ось "поперёк", а какая
                                     "вдоль" — зависит от Slider.Orientation, отсюда триггер. -->
                                <Border CornerRadius="2" Background="{DynamicResource ControlStrongFillColorDefaultBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Height" Value="4" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Orientation}" Value="Vertical">
                                                    <Setter Property="Height" Value="Auto" />
                                                    <Setter Property="Width" Value="4" />
                                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Orientation="{TemplateBinding Orientation}" — Track это
                                     отдельный класс со своим СОБСТВЕННЫМ свойством Orientation
                                     (Horizontal по умолчанию), которое WPF не подхватывает из
                                     Slider автоматически просто по факту родства в шаблоне: без
                                     этой привязки Track всегда считал себя горизонтальным и
                                     мапил перетаскивание мышью на X, а не на Y — то есть на
                                     вертикальных слайдерах эквалайзера вертикальное движение
                                     мыши в принципе ни на что не влияло. -->
                                <Track x:Name="PART_Track" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                       Orientation="{TemplateBinding Orientation}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <!-- Тот же приём, что и у фоновой полосы выше: заполненная
                                                         акцентом часть трека "от начала до текущего значения"
                                                         должна быть тонкой поперёк оси движения и растянутой
                                                         вдоль неё. -->
                                                    <Border CornerRadius="2"
                                                            Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Height" Value="4" />
                                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Slider}, Path=Orientation}" Value="Vertical">
                                                                        <Setter Property="Height" Value="Auto" />
                                                                        <Setter Property="Width" Value="4" />
                                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <!-- Растягивается на всю выделенную Track'ом
                                                         область в обе стороны (Height/Width не
                                                         заданы — дефолт Stretch), поэтому для
                                                         этой, "прозрачной для глаза" половины
                                                         трека триггер по Orientation не нужен —
                                                         она только ловит клики мимо бегунка. -->
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb Width="16" Height="16" Cursor="Hand">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                             Stroke="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                                             StrokeThickness="1.5" />
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>


            <!-- Стилизация строк плейлиста: скруглённые карточки, ховер, акцентная подсветка выбранного трека.

                 Разделение треков между собой: раньше — линия снизу каждой строки, потом —
                 только нумерация без какого-либо фона (визуально пропадало на глаз). Теперь —
                 zebra striping: у каждой нечётной по счёту строки (AlternationIndex) свой
                 лёгкий фон-подложка (ControlFillColorDefaultBrush), у чётных — прозрачный.
                 Это задаётся триггером ниже (Style.Triggers), а не прямо в Background, потому
                 что AlternationIndex — это отдельное свойство самого ListViewItem, доступное
                 только когда ListView.AlternationCount > 0 (см. MainWindow.xaml).

                 Порядок важен: DataTrigger в Style.Triggers красит фон полосой ДО применения
                 шаблона, а ховер/выбор (ControlTemplate.Triggers ниже) красят именованный
                 элемент ItemBorder уже ПОСЛЕ — у триггеров шаблона приоритет выше, чем у
                 триггеров стиля, поэтому при наведении/выборе полоса всегда корректно
                 перекрывается акцентом, а не спорит с ним. -->
            <Style TargetType="ListViewItem">
                <Setter Property="Padding" Value="10,9" />
                <Setter Property="Margin" Value="2,3" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="ItemBorder" CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background"
                                            Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background"
                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <Binding RelativeSource="{RelativeSource Self}"
                                     Path="(ItemsControl.AlternationIndex)"
                                     Converter="{StaticResource IsOddIndexConverter}" />
                        </DataTrigger.Binding>
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
