<Window x:Class="AudioPlayer.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:AudioPlayer"
        Title="Мини-плеер"
        Width="220" Height="96"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- Мини-плеер теперь следует ТЕКУЩЕЙ теме приложения (светлая/тёмная), а не всегда
             тёмный, как было раньше. Текст, иконки и системные кнопки WPF-UI (ui:Button) внутри
             этого окна по умолчанию расшарены на DynamicResource-ресурсы ТЕКУЩЕЙ темы приложения
             — этого было бы достаточно самого по себе, НО фон окна (RootBorder) у нас не берётся
             из темы приложения, а всегда полупрозрачный (см. ApplyBackground) — поэтому светлый
             текст на светлом полупрозрачном фоне в светлой теме был бы плохо читаем без подгонки
             контраста под альфу фона.

             Переопределяем здесь, на уровне Window.Resources, те же самые ключи ресурсов, что
             использует и остальное приложение (TextFillColorPrimaryBrush и т.д.) — WPF ищет
             ресурс снизу вверх по дереву и найдёт ЭТИ значения раньше глобальных ресурсов темы
             приложения, поэтому автоматически подхватятся везде внутри окна: и в наших
             TextBlock/Border с DynamicResource, и во ВСТРОЕННЫХ шаблонах ui:Button — без
             необходимости лезть и переопределять их шаблоны вручную.

             Ресурсы намеренно получаются в code-behind через FindResource(...) по x:Key (см.
             ApplyTheme), а не через x:Name: WPF markup-компилятор не генерирует поле в
             code-behind для элемента внутри ResourceDictionary, если у него уже задан x:Key —
             x:Name в этом случае просто регистрируется в NameScope, но не создаёт поле класса,
             из-за чего сборка падает с CS0103 "имя не существует в текущем контексте". -->
        <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#C5FFFFFF" />
        <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#14FFFFFF" />
        <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="#26FFFFFF" />

        <!-- Индикатор громкости (см. VolumeIndicator ниже): плавно появляется и, спустя
             паузу, сам плавно исчезает. Запускается заново с нуля при каждом изменении
             громкости — см. ShowVolumeIndicator() в code-behind, которая останавливает
             предыдущий прогон анимации перед стартом нового, чтобы быстрые повторные
             нажатия хоткея не давали резких скачков прозрачности.

             Синхронно с ним (те же тайминги, тот же Storyboard) обложка+название+исполнитель
             (HeaderPanel) гаснут в ноль и появляются обратно — пока крутится громкость, в
             мини-плеере видно ТОЛЬКО процент громкости, а не обе надписи разом друг на друге. -->
        <Storyboard x:Key="VolumeIndicatorStoryboard">
            <DoubleAnimation Storyboard.TargetName="VolumeIndicator" Storyboard.TargetProperty="Opacity"
                              From="0" To="1" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="VolumeIndicator" Storyboard.TargetProperty="Opacity"
                              From="1" To="0" BeginTime="0:0:0.9" Duration="0:0:0.35" />

            <DoubleAnimation Storyboard.TargetName="HeaderPanel" Storyboard.TargetProperty="Opacity"
                              From="1" To="0" Duration="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="HeaderPanel" Storyboard.TargetProperty="Opacity"
                              From="0" To="1" BeginTime="0:0:0.9" Duration="0:0:0.35" />
        </Storyboard>
    </Window.Resources>

    <!-- Фон мини-плеера прошёл через несколько неудачных попыток, прежде чем осесть на нынешнем
         виде (см. git-историю, если интересны подробности): сначала Mica через ui:FluentWindow —
         не подошла именно этому маленькому окну без рамки (WindowStyle="None", 220×82/140):
         падала при входе в мини-режим, а после починки давала совсем не тот размер окна на
         экране. Затем — блюр через SetWindowCompositionAttribute (ACCENT_ENABLE_ACRYLICBLURBEHIND)
         — тоже отказались: это Win32-эффект композиции DWM, рассчитанный на обычные окна, а наше
         окно уже само по себе AllowsTransparency="True" (layered window, композитится через
         собственный, отдельный от DWM механизм альфа-смешивания WPF). Комбинация двух разных
         механизмов прозрачности на одном HWND ведёт себя непредсказуемо в зависимости от системы:
         на части машин итоговая видимая прозрачность переставала зависеть от нашего слайдера
         вообще (DWM просто держал свой собственный альфа-канал тонировки блюра поверх того, что
         выставляли мы), на части — эффект отключался тихо, если у пользователя в Параметрах
         Windows выключены эффекты прозрачности, и никакой ошибки за этим не следовало.

         Теперь фон — это ЕДИНСТВЕННЫЙ и полностью надёжный слой: RootBorder заливается сплошным
         цветом темы (см. ApplyTheme) с альфа-каналом из настройки "прозрачность мини-плеера" (см.
         ApplyBackground в code-behind). Поскольку окно уже AllowsTransparency="True", WPF сам,
         без всякого Win32-API, честно смешивает этот полупрозрачный цвет с тем, что реально
         находится на экране позади окна — рабочий стол или окна под мини-плеером становятся
         видны сквозь него тем отчётливее, чем ниже прозрачность в настройках. Это не блюр
         (то, что видно позади, не размывается), зато работает одинаково на любой системе и
         честно откликается на каждое движение слайдера — что и было целью. -->
    <Grid>
    <Border x:Name="RootBorder" CornerRadius="14"
            MouseEnter="RootBorder_MouseEnter" MouseLeave="RootBorder_MouseLeave"
            MouseWheel="RootBorder_MouseWheel">
        <Border.Background>
            <!-- Цвет и альфа-канал полностью выставляются в code-behind: базовый цвет — из
                 ApplyTheme (тёмный графит либо светло-серый, под тему приложения), альфа —
                 из ApplyBackground (настройка "прозрачность мини-плеера"). Значение ниже —
                 просто дефолт на первый кадр. -->
            <SolidColorBrush x:Name="MiniBackgroundBrush" Color="#F51C1C1E" />
        </Border.Background>
        <!-- ПКМ по любому месту мини-плеера: закрепление (запрет перетаскивания) и
             "поверх окон" — те же две настройки, что и в окне настроек, здесь просто
             под рукой. MiniPlayerContextMenu_Opened каждый раз перед показом меню
             подставляет актуальное состояние, так что галочки не могут разъехаться
             с реальными настройками, даже если их поменяли из другого места. -->
        <Border.ContextMenu>
            <ContextMenu Opened="MiniPlayerContextMenu_Opened">
                <MenuItem x:Name="PinnedMenuItem" Header="Закрепить" IsCheckable="True"
                          Click="PinnedMenuItem_Click" />
                <MenuItem x:Name="TopmostMenuItem" Header="Поверх окон" IsCheckable="True"
                          Click="TopmostMenuItem_Click" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Обложка + название/исполнитель. Здесь же перетаскиваем окно (своего заголовка нет). -->
            <StackPanel x:Name="HeaderPanel" Grid.Row="0" Orientation="Horizontal" Margin="14,10,14,2"
                        Background="Transparent"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border x:Name="ArtBorder" Width="42" Height="42" CornerRadius="8"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                    <local:SvgPathIcon x:Name="ArtIcon" Icon="IconMusicNote" Size="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Border>

                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <!-- Ширина 140 подобрана под фактически доступное место: 220 (окно) минус
                         14+14 (отступы StackPanel-заголовка) минус 42 (обложка) минус 10 (отступ
                         перед текстом) = 140. Окно мини-плеера имеет фиксированный размер
                         (ResizeMode="NoResize"), поэтому число не "поедет" при изменении окна.

                         TextBlock лежит внутри Canvas, а не прямо внутри Border: если бы он был
                         прямым ребёнком Border с фиксированной шириной 140, WPF сам, ещё ДО
                         применения RenderTransform, обрезал бы его отрисовку до этих 140px —
                         это автоматическое поведение layout-системы (обрезка элемента по
                         выделенному ему месту у родителя, когда его DesiredSize больше), отдельное
                         от ClipToBounds на самом Border. В результате прокручивать оказывалось
                         попросту нечего: часть названия за пределами 140px никогда не рисовалась,
                         и бегущая строка visually показывала только начало, сколько бы TitleTranslate
                         её ни сдвигал. Canvas же не обрезает детей по своим границам (даёт им
                         столько места, сколько они просят), поэтому TextBlock рисуется на полную
                         естественную ширину — а нужную видимую "рамку" по-прежнему обеспечивает
                         ClipToBounds самого Border снаружи. -->
                    <Border x:Name="TitleClipBorder" Width="140" ClipToBounds="True" HorizontalAlignment="Left">
                        <Canvas Height="18">
                            <TextBlock x:Name="TitleText" Text="Файл не выбран"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextWrapping="NoWrap" TextTrimming="None">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TitleTranslate" X="0" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Canvas>
                    </Border>
                    <TextBlock x:Name="ArtistText" Text="—" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Прогресс (простая полоса + прозрачный слой для перемотки кликом/перетаскиванием) -->
            <Grid Grid.Row="1" Margin="14,4,14,0" Height="20">
                <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                        Background="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                <Border x:Name="ProgressFill" Height="4" CornerRadius="2" Width="0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="{DynamicResource AccentFillColorDefaultBrush}" />
                <Border Background="Transparent"
                        MouseLeftButtonDown="Progress_MouseLeftButtonDown"
                        MouseMove="Progress_MouseMove"
                        MouseLeftButtonUp="Progress_MouseLeftButtonUp" />
            </Grid>

            <!-- Кнопки — показываются только при наведении курсора на окно -->
            <StackPanel x:Name="ControlsPanel" Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,8,0,10" Visibility="Collapsed">
                <ui:Button x:Name="RepeatButton" Appearance="Secondary"
                           Width="26" Height="26" Padding="0" Margin="3,0"
                           Click="RepeatButton_Click" ToolTip="Повтор: выключен">
                    <ui:Button.Icon>
                        <local:SvgPathIcon Icon="IconRepeatAll" Size="12" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button x:Name="PrevButton" Appearance="Secondary"
                           Width="30" Height="30" Padding="0" Margin="3,0"
                           Click="PrevButton_Click" ToolTip="Предыдущий">
                    <ui:Button.Icon>
                        <local:SvgPathIcon Icon="IconPrevious" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button x:Name="PlayPauseButton" Appearance="Primary"
                           Width="36" Height="36" Padding="0" Margin="3,0"
                           Click="PlayPauseButton_Click" ToolTip="Пуск/Пауза">
                    <ui:Button.Icon>
                        <local:SvgPathIcon Icon="IconPlay" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button x:Name="NextButton" Appearance="Secondary"
                           Width="30" Height="30" Padding="0" Margin="3,0"
                           Click="NextButton_Click" ToolTip="Следующий">
                    <ui:Button.Icon>
                        <local:SvgPathIcon Icon="IconNext" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button x:Name="RestoreButton" Appearance="Secondary"
                           Width="28" Height="28" Padding="0" Margin="3,0"
                           Click="RestoreButton_Click" ToolTip="Развернуть плеер">
                    <ui:Button.Icon>
                        <local:SvgPathIcon Icon="IconExpand" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Border>

    <!-- Всплывающий индикатор процентов громкости — сам появляется и исчезает (см.
         VolumeIndicatorStoryboard), синхронно с этим гаснет HeaderPanel (обложка+название+
         исполнитель), освобождая для него место — поэтому индикатор специально позиционируется
         НАД HeaderPanel (Top + отступ, подобранный под её фактическую высоту), а не по центру
         всего окна: у окна мини-плеера бывает две высоты (свёрнутая/с кнопками при наведении,
         см. CollapsedHeight/ExpandedHeight в MiniPlayerWindow.xaml.cs), и центр по всей высоте
         окна в развёрнутом состоянии попадал уже на полосу прогресса под заголовком — индикатор
         громкости налезал на неё вместо того, чтобы просто занять место погасшего заголовка.
         IsHitTestVisible="False", чтобы не мешать кликам/скроллу по мини-плееру, пока показан.
         Opacity="0" по умолчанию: без анимации полностью невидим, а не просто "пустой", чтобы
         не перехватывать события мыши даже на миллисекунду до первого запуска анимации. -->
    <Border x:Name="VolumeIndicator" CornerRadius="10" Padding="12,6"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0"
            Opacity="0" IsHitTestVisible="False">
        <StackPanel Orientation="Horizontal">
            <local:SvgPathIcon x:Name="VolumeIndicatorIcon" Icon="IconSpeaker" Size="14"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock x:Name="VolumeIndicatorText" Text="30%" FontSize="14" FontWeight="SemiBold"
                       Margin="7,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </StackPanel>
    </Border>
    </Grid>
</Window>
