<ui:FluentWindow x:Class="AudioPlayer.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Lumisense"
        Icon="/Icons/app/lumisense.ico"
        Height="200" Width="380"
        MinHeight="200" MinWidth="320"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <!-- Небольшое модальное окно "введите текст" — используется, например, для названия
         новой (ручной) папки плейлиста. Ничего специфичного для плейлиста в нём нет —
         заголовок, подсказка и текст по умолчанию задаются конструктором TextInputDialog,
         так что окно можно переиспользовать для любого другого места, где понадобится
         спросить у пользователя короткую строку. -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Lumisense" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="20,4,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptText" Grid.Row="0" Text="Введите значение:" FontSize="13" Margin="0,0,0,8" />

            <ui:TextBox x:Name="InputBox" Grid.Row="1" KeyDown="InputBox_KeyDown" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button x:Name="CancelButton" Content="Отмена" Appearance="Secondary"
                           Width="88" Margin="0,0,8,0" Click="CancelButton_Click" />
                <ui:Button x:Name="OkButton" Content="Создать" Appearance="Primary"
                           Width="88" Click="OkButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
