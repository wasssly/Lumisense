<ui:FluentWindow x:Class="AudioPlayer.TrackPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Свойства"
        Icon="/Icons/app/lumisense.ico"
        Height="480" Width="420"
        MinHeight="420" MinWidth="360"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <ui:FluentWindow.Resources>
        <!-- Одна строка "подпись — значение" внутри карточки свойств собирается прямо в
             разметке (без отдельного UserControl) — так же надёжнее без возможности
             прогнать компилятор здесь же, при правке. Просто заполняем .Text у именованных
             TextBlock из code-behind. -->
        <Style x:Key="PropLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="PropValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
        <Style x:Key="PropDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style x:Key="PropRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,4" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="PropsTitleBar" Grid.Row="0" Title="Свойства" ShowMaximize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,4,24,20">
            <StackPanel>

                <!-- Обложка + название/исполнитель — та же шапка, что и в самом плеере,
                     чтобы окно свойств сразу было узнаваемо "своим", а не системным -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                    <Border x:Name="ArtBorder" Width="64" Height="64" CornerRadius="10"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <TextBlock x:Name="ArtPlaceholder" Text="&#xE8D6;" FontFamily="Segoe Fluent Icons"
                                   FontSize="24" Opacity="0.4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="ArtistText" FontSize="13" Opacity="0.65" Margin="0,2,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Файл" FontSize="12" FontWeight="SemiBold" Opacity="0.55" Margin="0,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14,10" Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Имя файла" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="FileNameValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Папка" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="FolderValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Размер" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="SizeValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Формат" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="FormatValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Аудио" FontSize="12" FontWeight="SemiBold" Opacity="0.55" Margin="0,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14,10" Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Длительность" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="DurationValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Битрейт" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="BitrateValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Частота дискретизации" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="SampleRateValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Каналы" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="ChannelsValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Даты" FontSize="12" FontWeight="SemiBold" Opacity="0.55" Margin="0,0,0,8" />
                <Border CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="14,10">
                    <StackPanel>
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Создан" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="CreatedValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                        <Border Style="{StaticResource PropDividerStyle}" />
                        <Grid Style="{StaticResource PropRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Изменён" Style="{StaticResource PropLabelStyle}" />
                            <TextBlock x:Name="ModifiedValue" Grid.Column="1" Style="{StaticResource PropValueStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
