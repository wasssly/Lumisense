<ui:FluentWindow x:Class="AudioPlayer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:AudioPlayer"
        Title="Настройки"
        Icon="/Icons/app/lumisense.ico"
        Height="640" Width="760"
        MinHeight="520" MinWidth="680"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        PreviewKeyDown="SettingsWindow_PreviewKeyDown">

    <ui:FluentWindow.Resources>

        <!-- Стиль пунктов панели навигации слева: RadioButton без "кружка", вместо этого
             вся строка (иконка + подпись) подсвечивается фоном, когда пункт выбран. -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" CornerRadius="8" Background="Transparent">
                            <ContentPresenter Margin="12,10" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorDefaultBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Карточка-превью вида плеера в настройках: RadioButton с картинкой-миниатюрой
             внутри, подсвечивается акцентной рамкой, когда выбран (см. PageWindow /
             PlayerViewModeCard). -->
        <Style x:Key="ViewModeThumbStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" CornerRadius="10" BorderThickness="2"
                                BorderBrush="Transparent" Padding="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Карточка-секция настроек: используется на каждой странице -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!-- Заголовок страницы настроек -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <!-- Строка результата поиска настроек: прозрачная кнопка на всю ширину со скруглённой
             подсветкой при наведении, как у пунктов навигации -->
        <Style x:Key="SearchResultItemStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="12,9" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Настройки" ShowMaximize="False" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Панель навигации ===== -->
            <Border Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid Margin="12,12,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ui:TextBox x:Name="SettingsSearchBox" Grid.Row="0" Margin="0,0,0,10"
                                PlaceholderText="Поиск настроек"
                                ClearButtonEnabled="True"
                                TextChanged="SettingsSearchBox_TextChanged">
                        <ui:TextBox.Icon>
                            <local:SvgPathIcon Icon="IconSearch" />
                        </ui:TextBox.Icon>
                    </ui:TextBox>

                    <Grid Grid.Row="1">
                        <StackPanel x:Name="NavCategoriesPanel">

                    <RadioButton x:Name="NavAppearance" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="Appearance"
                                 Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconSun" Size="18" VerticalAlignment="Center" />
                            <TextBlock Text="Оформление" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavWindow" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="Window" Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconWindow" Size="18" VerticalAlignment="Center" />
                            <TextBlock Text="Окно" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavPlayback" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="Playback" Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconPlay" Size="16" VerticalAlignment="Center" />
                            <TextBlock Text="Воспроизведение" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavMiniPlayer" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="MiniPlayer" Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconPictureInPicture" Size="18" VerticalAlignment="Center" />
                            <TextBlock Text="Мини-плеер" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavHotkeys" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="Hotkeys" Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconKeyboard" Size="18" VerticalAlignment="Center" />
                            <TextBlock Text="Горячие клавиши" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <Separator Margin="4,8" Background="{DynamicResource ControlStrongFillColorDefaultBrush}" />

                    <RadioButton x:Name="NavAbout" Style="{StaticResource NavItemStyle}"
                                 GroupName="SettingsNav" Tag="About" Checked="NavItem_Checked">
                        <StackPanel Orientation="Horizontal">
                            <local:SvgPathIcon Icon="IconInfo" Size="18" VerticalAlignment="Center" />
                            <TextBlock Text="О программе" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                        </StackPanel>

                        <!-- ===== Результаты поиска настроек (заменяют список категорий, пока идёт поиск) ===== -->
                        <Grid x:Name="SearchResultsHost" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="SearchResultsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource SearchResultItemStyle}" Click="SearchResultItem_Click">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontSize="13" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding PageTitle}" FontSize="11" Opacity="0.55" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel x:Name="SearchEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                                <local:SvgPathIcon Icon="IconSearch" Size="22" Opacity="0.35" HorizontalAlignment="Center" />
                                <TextBlock Text="Ничего не найдено" Opacity="0.5" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== Содержимое выбранной страницы ===== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,20,24,20">

                    <!-- Оформление -->
                    <StackPanel x:Name="PageAppearance">
                        <TextBlock Text="Оформление" Style="{StaticResource PageTitleStyle}" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <CheckBox x:Name="LightThemeCheckBox" Content="Светлая тема"
                                          Checked="ThemeCheckBox_Changed" Unchecked="ThemeCheckBox_Changed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Окно -->
                    <StackPanel x:Name="PageWindow" Visibility="Collapsed">
                        <TextBlock Text="Окно" Style="{StaticResource PageTitleStyle}" />

                        <Border x:Name="PlayerViewModeCard" Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Вид плеера" FontWeight="SemiBold" Margin="0,0,0,2" />
                                <TextBlock Text="Как выглядит и какого размера главное окно плеера"
                                           Opacity="0.6" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal">

                                    <!-- Квадратный вид: крупный контент + открытый по умолчанию плейлист,
                                         занимающий всю ширину окна -->
                                    <RadioButton x:Name="ViewModeSquareRadio" Style="{StaticResource ViewModeThumbStyle}"
                                                 GroupName="PlayerViewModeGroup" Tag="Square" Margin="0,0,10,0"
                                                 Checked="PlayerViewModeRadio_Checked">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="64" Height="64" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <Grid Margin="6">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="26" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Ellipse Grid.Row="0" Width="22" Height="22"
                                                             Fill="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,4,0,0">
                                                        <Rectangle Height="5" Margin="0,0,0,3"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                        <Rectangle Height="5" Margin="0,0,0,3"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                        <Rectangle Height="5"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="Квадратный" Foreground="White" FontSize="12" Margin="0,6,0,0"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </RadioButton>

                                    <!-- Прямоугольный вид: обычные размеры элементов, плейлист виден сбоку/снизу -->
                                    <RadioButton x:Name="ViewModeRectangularRadio" Style="{StaticResource ViewModeThumbStyle}"
                                                 GroupName="PlayerViewModeGroup" Tag="Rectangular" Margin="0,0,10,0"
                                                 Checked="PlayerViewModeRadio_Checked">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="44" Height="64" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <Grid Margin="5">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="18" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Ellipse Grid.Row="0" Width="14" Height="14"
                                                             HorizontalAlignment="Center"
                                                             Fill="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,4,0,0">
                                                        <Rectangle Height="4" Margin="0,0,0,3"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                        <Rectangle Height="4" Margin="0,0,0,3"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                        <Rectangle Height="4" Margin="0,0,0,3"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                        <Rectangle Height="4"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="Прямоугольный" Foreground="White" FontSize="12" Margin="0,6,0,0"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </RadioButton>

                                    <!-- Мини-плеер: узкая горизонтальная плашка без плейлиста -->
                                    <RadioButton x:Name="ViewModeMiniRadio" Style="{StaticResource ViewModeThumbStyle}"
                                                 GroupName="PlayerViewModeGroup" Tag="Mini"
                                                 Checked="PlayerViewModeRadio_Checked">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="76" Height="64" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <Border Width="60" Height="20" CornerRadius="10"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                                        BorderThickness="1">
                                                    <Grid Margin="4,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                        <Rectangle Grid.Column="1" Height="4" Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}" />
                                                    </Grid>
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Мини-плеер" Foreground="White" FontSize="12" Margin="0,6,0,0"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </RadioButton>

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Поверх всех окон"
                                          Checked="AlwaysOnTopCheckBox_Changed" Unchecked="AlwaysOnTopCheckBox_Changed"
                                          Margin="0,0,0,8" />
                                <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Сворачивать в трей при закрытии"
                                          Checked="MinimizeToTrayCheckBox_Changed" Unchecked="MinimizeToTrayCheckBox_Changed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Воспроизведение -->
                    <StackPanel x:Name="PagePlayback" Visibility="Collapsed">
                        <TextBlock Text="Воспроизведение" Style="{StaticResource PageTitleStyle}" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <CheckBox x:Name="RememberVolumeCheckBox" Content="Запоминать громкость между запусками"
                                          Checked="RememberVolumeCheckBox_Changed" Unchecked="RememberVolumeCheckBox_Changed"
                                          Margin="0,0,0,8" />
                                <CheckBox x:Name="LogarithmicVolumeCheckBox" Content="Логарифмическая регулировка громкости"
                                          Checked="LogarithmicVolumeCheckBox_Changed" Unchecked="LogarithmicVolumeCheckBox_Changed" />
                                <TextBlock Text="Ползунок громкости меняет уровень так, как его воспринимает слух: заметный на глаз ход в начале и в конце шкалы звучит одинаково плавно, без резкого скачка на малой громкости."
                                           FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="26,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Мини-плеер -->
                    <StackPanel x:Name="PageMiniPlayer" Visibility="Collapsed">
                        <TextBlock Text="Мини-плеер" Style="{StaticResource PageTitleStyle}" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Прозрачность окна" VerticalAlignment="Center" />
                                    <TextBlock x:Name="MiniOpacityValueText" Grid.Column="1" Text="100%"
                                               Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
                                </Grid>

                                <!-- Тот же приём, что и у ползунка громкости в главном окне: сам Slider не
                                     ловит мышь, поверх него прозрачный Border обрабатывает клик/перетаскивание
                                     в любой точке трека целиком, без зависимости от того, куда именно попали
                                     (в шарик или в любую другую точку полосы). -->
                                <Grid Margin="0,0,0,14">
                                    <Slider x:Name="MiniOpacitySlider" IsHitTestVisible="False"
                                            Minimum="0.3" Maximum="1.0" Value="1.0"
                                            ValueChanged="MiniOpacitySlider_ValueChanged" VerticalAlignment="Center" />

                                    <Border Background="Transparent" Height="24" VerticalAlignment="Center"
                                            MouseLeftButtonDown="MiniOpacityOverlay_MouseLeftButtonDown"
                                            MouseMove="MiniOpacityOverlay_MouseMove"
                                            MouseLeftButtonUp="MiniOpacityOverlay_MouseLeftButtonUp" />
                                </Grid>

                                <CheckBox x:Name="MiniAlwaysOnTopCheckBox" Content="Поверх всех окон (мини-плеер)"
                                          Checked="MiniAlwaysOnTopCheckBox_Changed" Unchecked="MiniAlwaysOnTopCheckBox_Changed"
                                          Margin="0,0,0,8" />
                                <CheckBox x:Name="MiniPinnedCheckBox" Content="Закрепить положение (запретить перетаскивание)"
                                          Checked="MiniPinnedCheckBox_Changed" Unchecked="MiniPinnedCheckBox_Changed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Горячие клавиши -->
                    <StackPanel x:Name="PageHotkeys" Visibility="Collapsed">
                        <TextBlock Text="Горячие клавиши" Style="{StaticResource PageTitleStyle}" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Работают из любого окна, даже когда плеер свёрнут. Нажмите на комбинацию и введите новую — Esc отменяет запись."
                                           FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Пуск / пауза" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyPlayPauseButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyPlayPauseButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyPlayPauseClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Следующий трек" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyNextButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyNextButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyNextClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Предыдущий трек" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyPreviousButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyPreviousButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyPreviousClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Стоп" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyStopButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyStopButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyStopClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Громкость +" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyVolumeUpButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyVolumeUpButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyVolumeUpClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Громкость -" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyVolumeDownButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyVolumeDownButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyVolumeDownClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Без звука" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyMuteButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyMuteButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyMuteClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Перемешать" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyShuffleButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyShuffleButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyShuffleClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Режим повтора" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" x:Name="HotkeyRepeatButton" Appearance="Secondary"
                                               MinWidth="140" Margin="8,0,4,0" Click="HotkeyRepeatButton_Click" />
                                    <ui:Button Grid.Column="2" Appearance="Secondary" Width="28" Height="28" Padding="0"
                                               Click="HotkeyRepeatClearButton_Click" ToolTip="Очистить">
                                               <ui:Button.Icon>
                                                   <local:SvgPathIcon Icon="IconDismiss" />
                                               </ui:Button.Icon>
                                           </ui:Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- О программе (+ Патчноуты) -->
                    <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                        <TextBlock Text="О программе" Style="{StaticResource PageTitleStyle}" />

                        <Border Style="{StaticResource SettingsCardStyle}" x:Name="AboutInfoCard">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Source="/Icons/app/lumisense.png" Width="44" Height="44"
                                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                           Margin="0,0,12,0" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Lumisense" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock x:Name="AppVersionText" Text="Версия" Opacity="0.6" FontSize="12" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Аудиоплеер в стиле Fluent Design для Windows 11: плейлисты по папкам и файлам, мини-плеер, глобальные горячие клавиши и интеграция с «Сейчас воспроизводится»."
                                           TextWrapping="Wrap" Opacity="0.85" Margin="0,12,0,12" />

                                <TextBlock Text="Собрано на .NET 8, WPF-UI и NAudio." TextWrapping="Wrap"
                                           FontSize="12" Opacity="0.6" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Обновления" FontSize="14" FontWeight="SemiBold" Margin="4,20,0,10" />

                        <ui:Button x:Name="CheckUpdatesButton" Appearance="Secondary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                   Padding="16,14" Click="CheckUpdatesButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                        Background="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                        Margin="0,0,12,0">
                                    <local:SvgPathIcon Icon="IconCheckmark" Size="16"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="CheckUpdatesButtonTitle" Text="Проверить обновления" FontWeight="SemiBold" />
                                    <TextBlock x:Name="CheckUpdatesButtonSubtitle" Text="Сверить версию с GitHub" FontSize="12" Opacity="0.6" />
                                </StackPanel>
                            </Grid>
                        </ui:Button>

                        <TextBlock Text="Список изменений" FontSize="14" FontWeight="SemiBold" Margin="4,20,0,10" />

                        <ui:Button x:Name="ChangelogButton" Appearance="Secondary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                   Padding="16,14" Click="ChangelogButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                        Background="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                        Margin="0,0,12,0">
                                    <local:SvgPathIcon Icon="IconInfo" Size="16"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Список изменений" FontWeight="SemiBold" />
                                    <TextBlock Text="Что нового в текущей версии" FontSize="12" Opacity="0.6" />
                                </StackPanel>
                            </Grid>
                        </ui:Button>
                    </StackPanel>

                </Grid>
            </ScrollViewer>

        </Grid>
    </Grid>
</ui:FluentWindow>
