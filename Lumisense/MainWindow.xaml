<ui:FluentWindow x:Class="AudioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:AudioPlayer"
        Title="Lumisense"
        Icon="/Icons/app/lumisense.ico"
        Height="720" Width="440"
        MinHeight="680" MinWidth="400"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:FileNameConverter x:Key="FileNameConverter" />
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <local:ExpandChevronConverter x:Key="ExpandChevronConverter" />
        <local:TrackNumberConverter x:Key="TrackNumberConverter" />
        <local:TrackNumberFromListConverter x:Key="TrackNumberFromListConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Заголовок -->
            <RowDefinition Height="*" />      <!-- Тело: центрируется и масштабируется в полноэкранном режиме -->
        </Grid.RowDefinitions>

        <!-- Заголовок окна (Fluent TitleBar).
             ВАЖНО: ui:TitleBar перехватывает клики в СВОИХ границах на уровне Win32
             (WM_NCHITTEST → HTCAPTION) ещё до того, как они доходят до обычных WPF-элементов —
             поэтому прозрачный элемент, просто наложенный поверх TitleBar, кликов не получает.
             Чтобы кликабельная область на "Lumisense" реально работала, она вынесена в
             отдельную колонку СЛЕВА от TitleBar, а не поверх него — так эта часть экрана
             вообще не входит в границы TitleBar, и клики по ней обрабатываются как обычно. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="TitleClickArea" Grid.Column="0" VerticalAlignment="Stretch"
                    Background="Transparent" Cursor="Hand" Padding="16,0,4,0"
                    MouseLeftButtonUp="TitleClickArea_MouseLeftButtonUp"
                    ToolTip="Вид плеера">
                <TextBlock Text="Lumisense" FontSize="12" VerticalAlignment="Center" Opacity="0.9" />
                <Border.ContextMenu>
                    <ContextMenu Placement="Bottom">
                        <MenuItem x:Name="SquareViewMenuItem" Header="Обычный (квадратный)"
                                  IsCheckable="True" Tag="Square" Click="ViewModeMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconWindow" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="RectangularViewMenuItem" Header="Прямоугольный"
                                  IsCheckable="True" Tag="Rectangular" Click="ViewModeMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconPictureInPicture" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem x:Name="MiniViewMenuItem" Header="Мини-плеер"
                                  IsCheckable="True" Tag="Mini" Click="ViewModeMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconMinimizePlayer" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
            </Border>

            <!-- Title="" — стандартный текст TitleBar скрыт, вместо него слева стоит
                 кликабельный TitleClickArea из отдельной колонки выше -->
            <ui:TitleBar x:Name="AppTitleBar" Grid.Column="1" Title="" ShowMaximize="True" />
        </Grid>

        <!-- Тело окна обёрнуто в ContentHost: при разворачивании окна в полный экран кнопкой
             "Развернуть" в заголовке (WindowState -> Maximized) интерфейс не растягивается на
             всю ширину монитора "простынёй", а аккуратно центрируется и увеличивается — размеры
             считает ApplyFullscreenLayout()/UpdateContentMaxWidth() в MainWindow.xaml.cs по
             событию StateChanged. В обычном окне ContentHost ведёт себя как раньше (без изменений). -->
        <Border Grid.Row="1" x:Name="ContentHost" HorizontalAlignment="Stretch" MaxWidth="440">
            <Grid x:Name="BodyGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />      <!-- Заглушка: сохраняет исходную нумерацию Grid.Row="1".."6" ниже -->
                    <RowDefinition Height="Auto" />   <!-- Обложка / инфо о треке -->
                    <RowDefinition Height="Auto" />   <!-- Прогресс и время -->
                    <RowDefinition Height="Auto" />   <!-- Кнопки управления -->
                    <RowDefinition Height="Auto" />   <!-- Громкость -->
                    <RowDefinition Height="Auto" />   <!-- Панель плейлиста: заголовок + кнопки добавления -->
                    <RowDefinition Height="*" />      <!-- Плейлист (тянется, не вылезает за края) -->
                </Grid.RowDefinitions>

        <!-- Блок с обложкой и названием трека -->
        <StackPanel x:Name="AlbumArtPanel" Grid.Row="1" HorizontalAlignment="Center" Margin="0,8,0,8">
            <Border x:Name="AlbumArtBorder" Width="150" Height="150" CornerRadius="16"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    Cursor="Hand"
                    MouseLeftButtonDown="AlbumArtBorder_MouseLeftButtonDown"
                    ContextMenuOpening="AlbumArtBorder_ContextMenuOpening">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Скачать изображение…" Click="DownloadAlbumArtMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconAddFile" Size="13" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Копировать изображение" Click="CopyAlbumArtMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconCopy" Size="13" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Свойства" Click="AlbumArtPropertiesMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconInfo" Size="13" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <local:SvgPathIcon x:Name="AlbumArtIcon" Icon="IconMusicNote" Size="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Border>

            <TextBlock x:Name="TrackTitleText" Text="Файл не выбран"
                       FontSize="17" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,12,0,2"
                       TextTrimming="CharacterEllipsis" MaxWidth="360" />

            <TextBlock x:Name="TrackArtistText" Text="—"
                       FontSize="12" Opacity="0.6"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Прогресс воспроизведения -->
        <Grid Grid.Row="2" Margin="24,4,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Slider x:Name="ProgressSlider" IsHitTestVisible="False"
                        Minimum="0" Maximum="1" Value="0"
                        ValueChanged="ProgressSlider_ValueChanged" />

                <!-- Прозрачный слой поверх слайдера: сам обрабатывает мышь целиком,
                     чтобы не зависеть от того, куда именно попал клик — на трек или на шарик -->
                <Border Background="Transparent" Height="24"
                        MouseLeftButtonDown="ProgressOverlay_MouseLeftButtonDown"
                        MouseMove="ProgressOverlay_MouseMove"
                        MouseLeftButtonUp="ProgressOverlay_MouseLeftButtonUp" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,2,0,0">
                <TextBlock x:Name="CurrentTimeText" Text="00:00" HorizontalAlignment="Left" FontSize="11" Opacity="0.6" />
                <TextBlock x:Name="TotalTimeText" Text="00:00" HorizontalAlignment="Right" FontSize="11" Opacity="0.6" />
            </Grid>
        </Grid>

        <!-- Кнопки управления воспроизведением -->
        <StackPanel x:Name="ControlsPanel" Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,14,0,6">

            <ui:Button x:Name="ShuffleButton" Appearance="Secondary"
                       Width="40" Height="40" Margin="4,0"
                       Click="ShuffleButton_Click" ToolTip="Перемешать">
                <ui:Button.Icon>
                    <local:SvgPathIcon x:Name="ShuffleIcon" Icon="IconShuffle" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="RepeatButton" Appearance="Secondary"
                       Width="40" Height="40" Margin="4,0"
                       Click="RepeatButton_Click" ToolTip="Повтор: выключен">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconRepeatAll" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="PrevButton" Appearance="Secondary"
                       Width="44" Height="44" Margin="4,0"
                       Click="PrevButton_Click" ToolTip="Предыдущий">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconPrevious" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="PlayPauseButton" Appearance="Primary"
                       Width="54" Height="54" Margin="4,0"
                       Click="PlayPauseButton_Click" ToolTip="Пуск/Пауза">
                <ui:Button.Icon>
                    <local:SvgPathIcon x:Name="PlayPauseIcon" Icon="IconPlay" Size="15" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="NextButton" Appearance="Secondary"
                       Width="44" Height="44" Margin="4,0"
                       Click="NextButton_Click" ToolTip="Следующий">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconNext" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="StopButton" Appearance="Secondary"
                       Width="40" Height="40" Margin="4,0"
                       Click="StopButton_Click" ToolTip="Стоп">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconStop" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button x:Name="MiniModeButton" Appearance="Secondary"
                       Width="40" Height="40" Margin="4,0"
                       Click="MiniModeButton_Click" ToolTip="Свернуть в мини-плеер">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconMinimizePlayer" />
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <!-- Громкость -->
        <Grid x:Name="VolumeRow" Grid.Row="4" Margin="24,0,24,10" MouseWheel="VolumeRow_MouseWheel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0" x:Name="MuteButton" Appearance="Transparent"
                       Width="26" Height="26" Padding="0" Margin="0,0,6,0"
                       Click="MuteButton_Click" ToolTip="Без звука">
                <ui:Button.Icon>
                    <local:SvgPathIcon x:Name="SpeakerIcon" Icon="IconSpeaker" Size="15" />
                </ui:Button.Icon>
            </ui:Button>

            <Grid Grid.Column="1">
                <Slider x:Name="VolumeSlider" IsHitTestVisible="False"
                        Minimum="0" Maximum="1" Value="0.3"
                        ValueChanged="VolumeSlider_ValueChanged" VerticalAlignment="Center" />

                <Border Background="Transparent" Height="24" VerticalAlignment="Center"
                        MouseLeftButtonDown="VolumeOverlay_MouseLeftButtonDown"
                        MouseMove="VolumeOverlay_MouseMove"
                        MouseLeftButtonUp="VolumeOverlay_MouseLeftButtonUp" />
            </Grid>

            <TextBlock x:Name="VolumeValueText" Grid.Column="2" Text="30%"
                       FontSize="11" Opacity="0.6" Width="34"
                       VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Панель плейлиста: заголовок + переключатель видимости + кнопки добавления -->
        <Grid x:Name="PlaylistHeaderRow" Grid.Row="5" Margin="16,4,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Скрывает/показывает весь блок плейлиста целиком (не путать с шевроном
                 отдельной папки внутри него) -->
            <ui:Button Grid.Column="0" x:Name="TogglePlaylistButton" Appearance="Transparent"
                       Width="26" Height="26" Padding="0" Margin="0,0,4,0"
                       Click="TogglePlaylistButton_Click" ToolTip="Скрыть плейлист">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconChevronDown" />
                </ui:Button.Icon>
            </ui:Button>

            <TextBlock Grid.Column="1" Text="Плейлист" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" Opacity="0.85" />

            <!-- Одна кнопка вместо прежних "Файлы"/"Папка": клик открывает её собственное
                 контекстное меню с выбором, что именно добавлять. -->
            <ui:Button Grid.Column="2" x:Name="AddButton" Appearance="Secondary"
                       Content="Добавить" Margin="4,0"
                       Click="AddButton_Click" ToolTip="Добавить файлы или папку">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconAdd" />
                </ui:Button.Icon>
                <ui:Button.ContextMenu>
                    <ContextMenu Placement="Bottom">
                        <MenuItem Header="Файлы…" Click="AddFilesMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconAddFile" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Папку…" Click="AddFolderMenuItem_Click">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconAddFolder" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Новую папку…" Click="CreateFolderMenuItem_Click"
                                  ToolTip="Создать пустую папку в плейлисте и добавлять в неё файлы вручную">
                            <MenuItem.Icon>
                                <local:SvgPathIcon Icon="IconAdd" Size="14" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ui:Button.ContextMenu>
            </ui:Button>

            <ui:Button Grid.Column="3" x:Name="ClearPlaylistButton" Appearance="Secondary"
                       Width="32" Height="32" Padding="0" Margin="4,0,0,0"
                       Click="ClearPlaylistButton_Click" ToolTip="Очистить плейлист">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconDelete" />
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button Grid.Column="4" x:Name="SettingsButton" Appearance="Secondary"
                       Width="32" Height="32" Padding="0" Margin="4,0,0,0"
                       Click="SettingsButton_Click" ToolTip="Настройки">
                <ui:Button.Icon>
                    <local:SvgPathIcon Icon="IconSettings" />
                </ui:Button.Icon>
            </ui:Button>
        </Grid>

        <!-- Плейлист: список групп (папок/отдельных файлов). Каждую группу можно включить
             или выключить чекбоксом — выключенные пропускаются при воспроизведении,
             но остаются видны в списке (полупрозрачные). Клик по шеврону сворачивает/
             разворачивает список треков внутри группы. -->
        <Border x:Name="PlaylistBorder" Grid.Row="6" Margin="16,0,16,16" CornerRadius="10"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="PlaylistScrollViewer" Grid.Column="0" Margin="4"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              ScrollChanged="PlaylistScrollViewer_ScrollChanged">
                    <ItemsControl x:Name="PlaylistFoldersControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,2,2,10" CornerRadius="8" Padding="10,8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <StackPanel>
                                        <!-- Заголовок группы: чекбокс включения, шеврон сворачивания,
                                             название папки, счётчик, удаление -->
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  ToolTip="Включить/выключить эту папку в проигрывании" />

                                        <ui:Button Grid.Column="1" Appearance="Secondary"
                                                   Width="26" Height="26" Margin="0,0,4,0" Padding="0"
                                                   Click="ToggleFolderExpand_Click"
                                                   ToolTip="Свернуть/развернуть список треков">
                                            <ui:Button.Icon>
                                                <local:SvgPathIcon Icon="{Binding IsExpanded, Converter={StaticResource ExpandChevronConverter}}" />
                                            </ui:Button.Icon>
                                        </ui:Button>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                    Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacityConverter}}">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding SubtitleText}" FontSize="10" Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Только у "Отдельные файлы" и у папок, созданных вручную (не привязанных
                                             к реальной папке на диске) — добавить файлы прямо в эту группу -->
                                        <ui:Button Grid.Column="3" Appearance="Secondary"
                                                   Width="28" Height="28" Padding="0" Margin="0,0,4,0"
                                                   Click="AddFilesToFolderButton_Click"
                                                   Visibility="{Binding CanAddFilesDirectly, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   ToolTip="Добавить файлы в эту папку">
                                            <ui:Button.Icon>
                                                <local:SvgPathIcon Icon="IconAddFile" Size="13" />
                                            </ui:Button.Icon>
                                        </ui:Button>

                                        <ui:Button Grid.Column="4" Appearance="Secondary"
                                                   Width="28" Height="28" Padding="0"
                                                   Click="RemoveFolderButton_Click"
                                                   ToolTip="Убрать эту папку из плейлиста">
                                            <ui:Button.Icon>
                                                <local:SvgPathIcon Icon="IconDelete" />
                                            </ui:Button.Icon>
                                        </ui:Button>
                                    </Grid>

                                    <!-- Треки внутри группы. Подсветка текущего играющего трека — это то же самое
                                         выделение строки (IsSelected), что появляется при обычном клике мышью по
                                         треку (см. общий Style TargetType="ListViewItem" в App.xaml — скруглённая
                                         акцентная заливка). Никакой отдельной подсветки для "текущего трека" тут
                                         нет: код в MainWindow.xaml.cs при каждой смене трека сам выставляет
                                         SelectedItem нужной строки — то есть трек оказывается выделен ТОЧНО так же,
                                         как если бы пользователь кликнул по нему сам.

                                         Разделение треков между собой раньше держалось на тонкой линии снизу
                                         каждой строки — визуально это спорило со скруглёнными карточками
                                         hover/selected из App.xaml (линия + скруглённый акцент одновременно).
                                         Вместо линий — построчная нумерация слева (как в Spotify/Apple Music):
                                         она и так однозначно отделяет одну строку от другой, а на наведении
                                         мышью сама превращается в иконку воспроизведения, подсказывая, что по
                                         строке можно кликнуть. Номер берётся из AlternationIndex ListView
                                         (AlternationCount ниже намеренно завышен, чтобы индекс не зацикливался
                                         на реалистичных размерах плейлиста). -->
                                    <ListView Margin="0" Background="Transparent" BorderThickness="0"
                                              ItemsSource="{Binding Tracks}"
                                              AlternationCount="100000"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacityConverter}}"
                                              MouseDoubleClick="PlaylistTrackList_MouseDoubleClick"
                                              PreviewMouseWheel="PlaylistTrackList_PreviewMouseWheel">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Tag="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=DataContext}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Воспроизвести" Click="PlayTrackMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon>
                                                                    <local:SvgPathIcon Icon="IconPlay" Size="13" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="Показать в проводнике" Click="ShowInExplorerMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <MenuItem Header="Копировать путь к файлу" Click="CopyPathMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <MenuItem Header="Копировать файл" Click="CopyFileMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <Separator />
                                                            <MenuItem Header="Свойства" Click="TrackPropertiesMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <MenuItem Header="Изменить теги" Click="EditTagsMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon>
                                                                    <local:SvgPathIcon Icon="IconEdit" Size="13" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator />
                                                            <MenuItem Header="Убрать из плейлиста" Click="RemoveTrackMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                                <MenuItem.Icon>
                                                                    <local:SvgPathIcon Icon="IconDelete" Size="13" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="Удалить трек с диска…" Click="DeleteTrackFromDiskMenuItem_Click"
                                                                      CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      Foreground="#E53935">
                                                                <MenuItem.Icon>
                                                                    <local:SvgPathIcon Icon="IconDelete" Size="13" Foreground="#E53935" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Grid.ContextMenu>

                                                    <Grid Grid.Column="0" Width="26" Margin="0,0,4,0">
                                                        <TextBlock x:Name="TrackIndexText"
                                                                   FontSize="11" Opacity="0.5"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource TrackNumberFromListConverter}">
                                                                    <Binding />
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=ListView}" Path="ItemsSource" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <local:SvgPathIcon x:Name="TrackPlayIcon" Icon="IconPlay" Size="10"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="Collapsed" />
                                                    </Grid>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Converter={StaticResource FileNameConverter}}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True">
                                                        <Setter TargetName="TrackIndexText" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="TrackPlayIcon" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

                <!-- Свой скроллбар с нуля: никаких ScrollBar/Track — просто дорожка (Grid) и
                     ползунок (Border), позиция и размер которого целиком считаются вручную в
                     MainWindow.xaml.cs (PlaylistScrollViewer_ScrollChanged / Update...Thumb).
                     Клик по дорожке — мгновенный прыжок к месту клика, перетаскивание ползунка —
                     обычный драг за мышью. Никакой зависимости от внутренностей WPF ScrollBar.

                     Margin="0,4,0,4" — те же верхний/нижний отступы, что и у PlaylistScrollViewer
                     слева (Margin="4" со всех сторон): раньше у дорожки отступов не было вовсе,
                     из-за чего её ActualHeight была на 8px больше настоящей высоты видимой
                     прокручиваемой области — координаты ползунка считались по завышенной шкале
                     и на длинных плейлистах заметно "убегали" за пределы видимой дорожки.
                     ClipToBounds="True" — подстраховка на случай любых будущих округлений:
                     ползунок физически не может отрисоваться выше/ниже границ дорожки, даже
                     если Margin/Height на долю пикселя выйдут за расчётный диапазон. -->
                <Grid x:Name="PlaylistScrollTrack" Grid.Column="1" Background="Transparent"
                      Margin="0,4,0,4" ClipToBounds="True"
                      SizeChanged="PlaylistScrollTrack_SizeChanged"
                      MouseLeftButtonDown="PlaylistScrollTrack_MouseLeftButtonDown">
                    <Border x:Name="PlaylistScrollThumb" Width="5" CornerRadius="2.5"
                            HorizontalAlignment="Center" VerticalAlignment="Top"
                            Background="{DynamicResource ControlStrongFillColorDefaultBrush}"
                            Cursor="Hand" Visibility="Collapsed"
                            MouseLeftButtonDown="PlaylistScrollThumb_MouseLeftButtonDown"
                            MouseMove="PlaylistScrollThumb_MouseMove"
                            MouseLeftButtonUp="PlaylistScrollThumb_MouseLeftButtonUp" />
                </Grid>
            </Grid>
        </Border>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
